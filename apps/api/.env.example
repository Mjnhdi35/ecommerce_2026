NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
LOG_LEVEL=debug
BODY_LIMIT=100kb
SLOW_REQUEST_MS=500
REQUEST_TIMEOUT_MS=10000
CLIENT_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_SECRET=change-me-csrf-secret-at-least-32-characters
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
DEFAULT_CURRENCY=VND
MONGO_URL=mongodb://localhost:27017
DB_NAME=ecommerce
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
